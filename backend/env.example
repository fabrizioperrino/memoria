# Copiá este archivo como .env y completá los valores

# Groq — conseguís la key en https://console.groq.com/
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — conseguís las keys en https://supabase.com/dashboard
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=tu_supabase_service_role_key_aqui
SUPABASE_JWT_SECRET=tu_jwt_secret_aqui

# CORS — orígenes permitidos separados por coma
# En desarrollo:
ALLOWED_ORIGINS=http://localhost:3000
# En producción (reemplazá con tu URL de Vercel):
# ALLOWED_ORIGINS=http://localhost:3000,https://memoria-app.vercel.app
